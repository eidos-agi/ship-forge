# Publish to PyPI via trusted publisher (OIDC) with pre-publish verification.
# Triggered by pushing a version tag: git tag v0.1.0 && git push --tags
#
# Prerequisites:
#   1. Create a "pypi" environment in GitHub repo settings
#   2. Configure trusted publisher on PyPI:
#      - PyPI project name: {{PROJECT_SLUG}}
#      - Owner: {{GITHUB_ORG}}
#      - Repository: {{GITHUB_REPO}}
#      - Workflow: publish.yml
#      - Environment: pypi

name: Publish to PyPI

on:
  push:
    tags: ["v*"]

jobs:
  verify:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - name: Build
        run: |
          pip install build twine
          python -m build
      - name: Verify metadata
        run: twine check dist/*
      - name: Verify wheel installs
        run: |
          python -m venv /tmp/verify
          /tmp/verify/bin/pip install dist/*.whl
          /tmp/verify/bin/python -c "import {{MODULE}}"
      - uses: actions/upload-artifact@v4
        with:
          name: dist
          path: dist/

  publish:
    needs: verify
    runs-on: ubuntu-latest
    environment: pypi
    permissions:
      id-token: write
      contents: read
    steps:
      - uses: actions/download-artifact@v4
        with:
          name: dist
          path: dist/
      - name: Publish to PyPI
        uses: pypa/gh-action-pypi-publish@release/v1
